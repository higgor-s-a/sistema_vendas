# Arquivo de exemplo para variáveis de ambiente
# Copie este arquivo para .env e configure os valores

# Modo de operação
# true = usa dados mockados (seguro para repositório público)
# false = conecta ao Google Sheets real (requer credenciais)
DEMO_MODE=true

# Credenciais do Google Service Account (apenas para produção - DEMO_MODE=false)
# GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"..."}

# Chave secreta para sessões Flask (recomendado)
# SECRET_KEY=your-secret-key-here

# URL da planilha Google Sheets (apenas para produção)
# GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit

# === Para Vercel ===
# Configure estas variáveis no painel do Vercel (Settings > Environment Variables)
# - DEMO_MODE
# - GOOGLE_SHEETS_CREDENTIALS (se usar modo produção)
# - SECRET_KEY
#   "auth_uri": "https://accounts.google.com/o/oauth2/auth",
#   "token_uri": "https://oauth2.googleapis.com/token",
#   "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
#   "client_x509_cert_url": "..."
# }

# Para configurar no Vercel:
# 1. Dashboard > Project Settings > Environment Variables
# 2. Add Variable: GOOGLE_SHEETS_CREDENTIALS
# 3. Value: Cole o JSON completo das credenciais (tudo em uma linha)