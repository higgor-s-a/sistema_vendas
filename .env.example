# Exemplo de como configurar as variáveis de ambiente no Vercel
# Copie o conteúdo do seu arquivo credenciais.json e use como valor da variável

# GOOGLE_SHEETS_CREDENTIALS = {
#   "type": "service_account",
#   "project_id": "your-project-id",
#   "private_key_id": "...",
#   "private_key": "-----BEGIN PRIVATE KEY-----\n...",
#   "client_email": "your-service-account@your-project.iam.gserviceaccount.com",
#   "client_id": "...",
#   "auth_uri": "https://accounts.google.com/o/oauth2/auth",
#   "token_uri": "https://oauth2.googleapis.com/token",
#   "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
#   "client_x509_cert_url": "..."
# }

# Para configurar no Vercel:
# 1. Dashboard > Project Settings > Environment Variables
# 2. Add Variable: GOOGLE_SHEETS_CREDENTIALS
# 3. Value: Cole o JSON completo das credenciais (tudo em uma linha)